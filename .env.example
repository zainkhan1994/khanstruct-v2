# Web3Forms access key for the contact message panel.
# Get a free key at https://web3forms.com (sign up with the inbox you want
# messages delivered to — e.g. zain@thekhanstruct.com), then copy this file to
# .env.local and paste the key below. Also set this var in your hosting env.
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
